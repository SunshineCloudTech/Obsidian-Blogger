# ============================================
#  环境变量配置模板
#  复制此文件为 .env 并修改对应值
# ============================================

# ---- 本地开发 ----
SITE_URL=http://localhost:4321
BASE_URL=/

# ---- GitHub Pages 部署 ----
# SITE_URL=https://sunshinecloudtech.github.io
# BASE_URL=/Obsidian-Blogger/

# ---- 自定义域名部署 ----
# SITE_URL=https://yourdomain.com
# BASE_URL=/

# ============================================
#  注意事项：
#  1. SITE_URL 末尾不要加斜杠
#  2. BASE_URL 必须以斜杠开头和结尾
#  3. GitHub Pages 的 BASE_URL 必须与仓库名一致
#  4. 自定义域名使用 / 作为 BASE_URL
# ============================================