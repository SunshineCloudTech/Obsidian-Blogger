---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="copyright">
			&copy; {today.getFullYear()} SunshineCloud. 保留所有权利。
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 3rem 1rem;
		background: rgba(var(--gray-light), 0.5);
		color: rgb(var(--gray));
		border-top: 1px solid rgba(var(--gray), 0.1);
	}

	.footer-content {
		max-width: 920px;
		margin: 0 auto;
		text-align: center;
	}

	.copyright {
		font-size: 0.9rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 720px) {
		footer {
			padding: 2rem 1rem;
		}
	}
</style>
